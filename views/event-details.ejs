<div class="event-details">
    <div class="event-header">
        <div class="event-header-content">
            <span class="category-badge">
                <%= event.category %>
            </span>
            <h1>
                <%= event.title %>
            </h1>
            <p class="event-meta">
                <span>📅 <%= event.date.toDateString() %> at <%= event.time %></span> |
                <span>📍 <%= event.location %></span>
            </p>
        </div>
        <div class="event-actions">

            <!-- LIKE BUTTON -->
            <form action="/events/<%= event._id %>/like" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-outline">
                    <%= user && event.likes.some(id=> id.toString() === user.id)
                        ? '❤️ Liked'
                        : '🤍 Like' %>
                        (<%= event.likes.length %>)
                </button>
            </form>

            <!-- REGISTER BUTTON -->
            <% if (user && !isRegistered && user.id !==event.organizer._id.toString()) { %>
                <form action="/events/<%= event._id %>/register" method="POST" style="display:inline;">
                    <button type="submit" class="btn">Register Now</button>
                </form>
                <% } else if (isRegistered) { %>
                    <button class="btn btn-disabled" disabled>Registered ✅</button>
                    <% } %>

                        <!-- EDIT + DELETE (ONLY ORGANIZER) -->
                        <% if (user && user.id===event.organizer._id.toString()) { %>

                            <a href="/events/<%= event._id %>/edit" class="btn">
                                Edit
                            </a>

                            <form action="/events/<%= event._id %>/delete" method="POST" style="display:inline;"
                                onsubmit="return confirm('Are you sure you want to delete this event?');">
                                <button type="submit" class="btn btn-danger">
                                    Delete
                                </button>
                            </form>

                            <% } %>

        </div>
    </div>

    <div class="event-main">
        <div class="event-description">
            <h2>About this event</h2>
            <p>
                <%= event.description %>
            </p>
            <div class="organizer-info">
                <p>Organized by <strong>
                        <%= event.organizer.name %>
                    </strong></p>
            </div>
        </div>

        <section class="comments-section">
            <h3>Comments (<%= comments.length %>)</h3>
            <% if (user) { %>
                <form action="/events/<%= event._id %>/comment" method="POST" class="comment-form">
                    <textarea name="content" required placeholder="Write a comment..." rows="3"></textarea><br>
                    <button type="submit" class="btn">Post Comment</button>
                </form>
                <% } else { %>
                    <p><a href="/auth/login">Login</a> to leave a comment.</p>
                    <% } %>

                        <div class="comments-list">
                            <% comments.forEach(comment=> { %>
                                <div class="comment">
                                    <div class="comment-meta">
                                        <strong>
                                            <%= comment.user.name %>
                                        </strong>
                                        <span>
                                            <%= comment.createdAt.toLocaleString() %>
                                        </span>
                                    </div>
                                    <p>
                                        <%= comment.content %>
                                    </p>
                                </div>
                                <% }) %>
                        </div>
        </section>
    </div>
</div>